# BYOK — a chave nunca é embutida no pacote. Copie para .env (git-ignored).
# Defina apenas a do provider que for usar.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Alterna o provider no exemplo examples/blog-pt (default: anthropic):
# VERBOSIA_PROVIDER=gemini
# VERBOSIA_MODEL=gemini-2.0-flash

# v1 (opcional): TM compartilhada via Redis
# REDIS_URL=redis://localhost:6379
